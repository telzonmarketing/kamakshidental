<script src="analytics-config.js"></script>
<script defer src="analytics.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
--navy:#264969;
--navy2:#071929;
--teal:#0b7a6a;
--teal2:#0d9e8a;
--lime:#add253;
--lime2:#b8e032;
--white:#fff;
--offwhite:#f5f7f2;
--gray:#eef0eb;
--text:#333333;
--muted:#5a6a7a;
--border:#dde3dd;
--gold:#e8b84b;
}
html{scroll-behavior:smooth;}
body{font-family:'Poppins',sans-serif;color:var(--text);background:var(--white);overflow-x:hidden;}
a{text-decoration:none;}
img{max-width:100%;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--navy);}
::-webkit-scrollbar-thumb{background:var(--teal);}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;transition:all 0.3s;}
nav.scrolled{background:rgba(38,73,105,0.97);backdrop-filter:blur(20px);}
.nav-inner{max-width:1300px;margin:0 auto;padding:0 5%;display:flex;align-items:center;justify-content:space-between;height:72px;}
.logo-wrap{display:flex;align-items:center;min-width:0;}
.logo-wrap img{display:block;width:100%;height:auto;max-width:280px;}
.nav-menu{display:flex;align-items:center;gap:8px;}
.nav-menu a{font-size:13px;color:rgba(255,255,255,0.7);padding:8px 14px;border-radius:8px;transition:all 0.2s;font-weight:400;}
.nav-menu a:hover{color:white;background:rgba(255,255,255,0.08);}
.nav-book{background:var(--lime);color:var(--navy)!important;font-weight:600!important;border-radius:50px!important;padding:10px 22px!important;}
.nav-book:hover{background:var(--lime2);transform:translateY(-1px);}

/* HERO */
.hero{min-height:100vh;background:var(--navy);display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;padding:100px 5% 60px;}
.hero-bg-circle1{position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(11,122,106,0.15) 0%,transparent 70%);top:-200px;right:-100px;pointer-events:none;}
.hero-bg-circle2{position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(212,245,60,0.06) 0%,transparent 70%);bottom:-100px;left:10%;pointer-events:none;}
.hero-grid{max-width:1300px;margin:0 auto;width:100%;display:grid;grid-template-columns:1.1fr 0.9fr;gap:80px;align-items:center;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;margin-bottom:28px;}
.eyebrow-dot{width:8px;height:8px;background:var(--lime);border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.6;transform:scale(1.3);}}
.eyebrow-text{font-size:12px;color:var(--lime);font-weight:600;letter-spacing:0.15em;text-transform:uppercase;}
.hero h1{font-family:'Poppins',sans-serif;font-size:58px;font-weight:800;color:white;line-height:1.1;margin-bottom:24px;}
.hero h1 .accent{color:var(--lime);}
.hero h1 .teal{color:var(--teal2);}
.hero-sub{font-size:17px;color:rgba(255,255,255,0.6);line-height:1.7;margin-bottom:40px;max-width:520px;}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:56px;}
.btn-lime{background:var(--lime);color:var(--navy);padding:16px 32px;border-radius:50px;font-weight:600;font-size:15px;transition:all 0.25s;display:inline-flex;align-items:center;gap:8px;}
.btn-lime:hover{background:var(--lime2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(173,210,83,0.3);}
.btn-ghost{border:1px solid rgba(255,255,255,0.2);color:white;padding:16px 32px;border-radius:50px;font-weight:400;font-size:15px;transition:all 0.25s;display:inline-flex;align-items:center;gap:8px;}
.btn-ghost:hover{border-color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.05);}
.hero-trust{display:flex;gap:40px;}
.trust-item{text-align:center;}
.trust-num{font-family:'Poppins',sans-serif;font-size:36px;font-weight:800;color:var(--lime);}
.trust-label{font-size:12px;color:rgba(255,255,255,0.4);margin-top:2px;}
.hero-right{position:relative;}
.hero-card-main{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:24px;padding:28px;backdrop-filter:blur(20px);}
.hc-label{font-size:11px;color:var(--teal2);font-weight:600;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:8px;}
.hc-label::before{content:'';display:block;width:24px;height:1px;background:var(--teal2);}
.loc-row{display:flex;gap:14px;padding:16px 0;border-bottom:1px solid rgba(255,255,255,0.06);cursor:pointer;transition:all 0.2s;}
.loc-row:last-child{border-bottom:none;}
.loc-row:hover{padding-left:4px;}
.loc-row:hover .loc-row-name{color:var(--lime);}
.loc-num{font-family:'Poppins',sans-serif;font-size:28px;font-weight:800;color:rgba(255,255,255,0.06);line-height:1;flex-shrink:0;width:40px;}
.loc-row-info{flex:1;}
.loc-row-name{font-family:'Poppins',sans-serif;font-size:16px;font-weight:700;color:white;margin-bottom:4px;transition:color 0.2s;}
.loc-row-addr{font-size:12px;color:rgba(255,255,255,0.4);line-height:1.5;margin-bottom:4px;}
.loc-row-phone{font-size:13px;color:var(--teal2);font-weight:500;}
.hero-rating-badge{background:var(--lime);border-radius:14px;padding:14px 18px;margin-top:16px;display:flex;align-items:center;gap:14px;}
.rating-stars{font-size:18px;color:var(--navy);letter-spacing:2px;}
.rating-text{font-size:13px;color:var(--navy);font-weight:600;}
.rating-sub{font-size:11px;color:rgba(38,73,105,0.6);font-weight:400;}

/* MARQUEE */
.marquee-wrap{background:var(--teal);padding:14px 0;overflow:hidden;}
.marquee-inner{display:flex;gap:0;white-space:nowrap;animation:marquee 25s linear infinite;}
@keyframes marquee{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.marquee-item{font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;color:white;padding:0 40px;letter-spacing:0.05em;display:flex;align-items:center;gap:12px;}
.marquee-item::after{content:'';color:rgba(255,255,255,0.4);font-size:10px;}

/* LOCATION SECTIONS — FULL SEO PAGES */
.loc-section{padding:100px 5%;position:relative;}
.loc-section:nth-child(odd){background:var(--offwhite);}
.loc-section:nth-child(even){background:var(--white);}
.loc-section-inner{max-width:1300px;margin:0 auto;}
.loc-header{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;margin-bottom:64px;}
.loc-number{font-family:'Poppins',sans-serif;font-size:120px;font-weight:800;color:rgba(0,0,0,0.04);line-height:1;margin-bottom:-20px;}
.loc-tag{font-size:11px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--teal);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.loc-tag::before{content:'';display:block;width:24px;height:1px;background:var(--teal);}
.loc-h2{font-family:'Poppins',sans-serif;font-size:42px;font-weight:800;color:var(--navy);line-height:1.15;margin-bottom:16px;}
.loc-h2 span{color:var(--teal);}
.loc-desc{font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:24px;}
.loc-address-box{background:var(--navy);border-radius:16px;padding:24px;}
.lab-row{display:flex;gap:12px;margin-bottom:12px;align-items:flex-start;}
.lab-row:last-child{margin-bottom:0;}
.lab-icon{width:6px;height:6px;background:var(--teal2);border-radius:50%;flex-shrink:0;margin-top:7px;}
.lab-text{font-size:13px;color:rgba(255,255,255,0.7);line-height:1.5;}
.lab-text strong{color:white;display:block;margin-bottom:1px;}
.loc-services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:48px;}
.loc-svc{background:white;border:1px solid var(--border);border-radius:14px;padding:20px;transition:all 0.25s;}
.loc-svc:hover{border-color:var(--teal);box-shadow:0 6px 20px rgba(11,122,106,0.1);transform:translateY(-2px);}
.loc-svc-icon{font-size:24px;margin-bottom:10px;}
.loc-svc-name{font-family:'Poppins',sans-serif;font-size:15px;font-weight:700;color:var(--navy);margin-bottom:6px;}
.loc-svc-desc{font-size:12px;color:var(--muted);line-height:1.6;}
.loc-svc-kw{font-size:11px;color:var(--teal);font-weight:600;margin-top:8px;}
.loc-faq{margin-top:48px;}
.loc-faq h3{font-family:'Poppins',sans-serif;font-size:24px;font-weight:700;color:var(--navy);margin-bottom:24px;}
.faq-item{border:1px solid var(--border);border-radius:12px;margin-bottom:10px;overflow:hidden;transition:all 0.2s;}
.faq-item.open{border-color:var(--teal);}
.faq-q{padding:18px 20px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;gap:16px;}
.faq-q-text{font-size:15px;font-weight:500;color:var(--navy);}
.faq-icon{width:28px;height:28px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--teal);flex-shrink:0;transition:all 0.2s;}
.faq-item.open .faq-icon{background:var(--teal);color:white;border-color:var(--teal);}
.faq-a{padding:0 20px;max-height:0;overflow:hidden;transition:all 0.3s;font-size:14px;color:var(--muted);line-height:1.7;}
.faq-item.open .faq-a{padding:0 20px 18px;max-height:300px;}
.loc-cta-strip{background:var(--navy);border-radius:20px;padding:32px;display:flex;align-items:center;justify-content:space-between;gap:24px;margin-top:48px;flex-wrap:wrap;}
.loc-cta-text{font-family:'Poppins',sans-serif;font-size:22px;font-weight:700;color:white;}
.loc-cta-sub{font-size:14px;color:rgba(255,255,255,0.5);margin-top:4px;}
.btn-lime-sm{background:var(--lime);color:var(--navy);padding:14px 28px;border-radius:50px;font-weight:600;font-size:14px;white-space:nowrap;transition:all 0.2s;display:inline-block;}
.btn-lime-sm:hover{background:var(--lime2);}

/* SERVICES OVERVIEW */
.services-section{background:var(--navy);padding:100px 5%;}
.services-inner{max-width:1300px;margin:0 auto;}
.svc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:64px;background:rgba(255,255,255,0.04);border-radius:20px;overflow:hidden;}
.svc-cell{padding:32px 24px;border:1px solid rgba(255,255,255,0.06);transition:all 0.3s;cursor:pointer;background:rgba(255,255,255,0.02);}
.svc-cell:hover{background:rgba(13,158,138,0.15);border-color:rgba(13,158,138,0.3);}
.svc-cell-icon{font-size:32px;margin-bottom:16px;}
.svc-cell-name{font-family:'Poppins',sans-serif;font-size:16px;font-weight:700;color:white;margin-bottom:8px;}
.svc-cell-desc{font-size:13px;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:12px;}
.svc-cell-locs{font-size:11px;color:var(--teal2);font-weight:600;}
.svc-cell-price{font-size:12px;color:rgba(255,255,255,0.3);margin-top:6px;}

/* KEYWORDS CLOUD — hidden for humans, visible to Google */
.seo-keywords{font-size:1px;color:transparent;height:1px;overflow:hidden;position:absolute;}

/* WHY */
.why-section{padding:100px 5%;background:var(--gray);}
.why-inner{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.why-list{margin-top:40px;display:flex;flex-direction:column;gap:0;}
.why-row{display:flex;gap:20px;padding:24px 0;border-bottom:1px solid var(--border);align-items:flex-start;}
.why-row:last-child{border-bottom:none;}
.why-icon-box{width:48px;height:48px;background:var(--navy);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.why-row-title{font-family:'Poppins',sans-serif;font-size:16px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.why-row-desc{font-size:14px;color:var(--muted);line-height:1.6;}
.awards-panel{background:var(--navy);border-radius:24px;padding:40px;overflow:hidden;position:relative;}
.awards-panel::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:rgba(212,245,60,0.06);}
.award-row{display:flex;gap:18px;align-items:center;padding:20px 0;border-bottom:1px solid rgba(255,255,255,0.07);}
.award-row:last-child{border-bottom:none;}
.award-val{font-family:'Poppins',sans-serif;font-size:42px;font-weight:800;color:var(--lime);width:72px;flex-shrink:0;line-height:1;}
.award-title{font-size:15px;font-weight:500;color:white;margin-bottom:3px;}
.award-sub{font-size:13px;color:rgba(255,255,255,0.35);}

/* TECH */
.tech-section{padding:100px 5%;background:var(--white);}
.tech-inner{max-width:1300px;margin:0 auto;}
.tech-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:64px;}
.tech-card{border:1px solid var(--border);border-radius:20px;padding:32px;transition:all 0.3s;}
.tech-card:hover{border-color:var(--teal);box-shadow:0 8px 32px rgba(11,122,106,0.08);}
.tech-icon{font-size:36px;margin-bottom:16px;}
.tech-name{font-family:'Poppins',sans-serif;font-size:18px;font-weight:700;color:var(--navy);margin-bottom:8px;}
.tech-desc{font-size:14px;color:var(--muted);line-height:1.7;}
.tech-badge{display:inline-block;font-size:11px;font-weight:600;color:var(--teal);background:rgba(11,122,106,0.08);padding:4px 10px;border-radius:50px;margin-top:12px;}

/* REVIEWS */
.reviews-section{padding:100px 5%;background:var(--navy);}
.reviews-inner{max-width:1300px;margin:0 auto;}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:64px;}
.review-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:20px;padding:28px;transition:all 0.3s;}
.review-card:hover{background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.12);}
.review-stars{color:var(--gold);font-size:16px;letter-spacing:3px;margin-bottom:14px;}
.review-text{font-size:14px;color:rgba(255,255,255,0.65);line-height:1.8;margin-bottom:20px;font-style:italic;}
.review-author{font-family:'Poppins',sans-serif;font-size:15px;font-weight:700;color:white;}
.review-loc{font-size:12px;color:var(--teal2);margin-top:2px;}
.review-treatment{font-size:11px;color:rgba(255,255,255,0.3);margin-top:4px;}

/* APPOINTMENT */
.appt-section{padding:100px 5%;background:var(--offwhite);}
.appt-inner{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:1fr 1.2fr;gap:80px;align-items:start;}
.appt-left-tag{font-size:11px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--teal);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.appt-left-tag::before{content:'';display:block;width:24px;height:1px;background:var(--teal);}
.appt-h2{font-family:'Poppins',sans-serif;font-size:44px;font-weight:800;color:var(--navy);line-height:1.1;margin-bottom:20px;}
.appt-desc{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:36px;}
.appt-contact-list{display:flex;flex-direction:column;gap:16px;}
.appt-contact{display:flex;gap:14px;align-items:flex-start;}
.appt-contact-icon{width:8px;height:8px;background:var(--teal);border-radius:2px;flex-shrink:0;margin-top:6px;}
.appt-contact-name{font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;color:var(--navy);}
.appt-contact-val{font-size:13px;color:var(--muted);margin-top:2px;}
.appt-contact-phone{font-size:14px;color:var(--teal);font-weight:600;margin-top:2px;}
.form-card{background:white;border-radius:24px;padding:40px;border:1px solid var(--border);box-shadow:0 4px 40px rgba(0,0,0,0.05);}
.form-h3{font-family:'Poppins',sans-serif;font-size:22px;font-weight:700;color:var(--navy);margin-bottom:28px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{margin-bottom:16px;}
label{font-size:12px;font-weight:600;color:var(--muted);letter-spacing:0.05em;text-transform:uppercase;display:block;margin-bottom:6px;}
input,select,textarea{width:100%;padding:13px 16px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:'Poppins',sans-serif;color:var(--text);background:var(--offwhite);transition:all 0.2s;outline:none;}
input:focus,select:focus,textarea:focus{border-color:var(--teal);background:white;}
textarea{resize:vertical;min-height:80px;}
.submit-btn{width:100%;background:var(--navy);color:white;border:none;padding:16px;border-radius:50px;font-size:15px;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;transition:all 0.25s;margin-top:8px;letter-spacing:0.02em;}
.submit-btn:hover{background:var(--teal);transform:translateY(-2px);}
.form-note{font-size:11px;color:var(--muted);text-align:center;margin-top:10px;}

/* FOOTER */
footer{background:#1a2e40;padding:80px 5% 32px;}
.footer-inner{max-width:1300px;margin:0 auto;}
.footer-top{display:grid;grid-template-columns:2.5fr 1fr 1fr 1fr;gap:60px;padding-bottom:60px;border-bottom:1px solid rgba(255,255,255,0.06);}
.footer-brand-desc{font-size:14px;color:rgba(255,255,255,0.35);line-height:1.8;margin-top:16px;max-width:280px;}
.footer-col h4{font-family:'Poppins',sans-serif;font-size:12px;font-weight:700;color:rgba(255,255,255,0.5);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:20px;}
.footer-col a{display:block;font-size:14px;color:rgba(255,255,255,0.35);margin-bottom:10px;transition:color 0.2s;}
.footer-col a:hover{color:var(--lime);}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:32px;flex-wrap:wrap;gap:16px;}
.footer-copy{font-size:13px;color:rgba(255,255,255,0.2);}
.footer-credit{font-size:13px;color:rgba(255,255,255,0.32);}
.footer-credit a{color:var(--lime);font-weight:600;}
.footer-credit a:hover{color:white;}
.footer-seo{font-size:11px;color:rgba(255,255,255,0.1);}

/* SECTION HEADERS */
.sec-eyebrow{font-size:11px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--teal);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.sec-eyebrow::before{content:'';display:block;width:24px;height:1px;background:var(--teal);}
.sec-h2{font-family:'Poppins',sans-serif;font-size:44px;font-weight:800;color:var(--navy);line-height:1.15;margin-bottom:16px;}
.sec-h2.white{color:white;}
.sec-desc{font-size:16px;color:var(--muted);line-height:1.7;max-width:580px;}
.sec-desc.white{color:rgba(255,255,255,0.5);}

/* MOBILE */
@media(max-width:900px){
  .hero-grid,.loc-header,.why-inner,.appt-inner,.footer-top{grid-template-columns:1fr;}
  .hero h1{font-size:38px;}
  .sec-h2,.loc-h2{font-size:30px;}
  .svc-grid{grid-template-columns:1fr 1fr;}
  .loc-services-grid,.tech-grid,.reviews-grid{grid-template-columns:1fr 1fr;}
  .nav-menu a:not(.nav-book){display:none;}
  .hero-trust{gap:24px;}
  .trust-num{font-size:28px;}
