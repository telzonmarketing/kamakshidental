<script>
window.addEventListener('scroll',()=>{
  document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>50);
});
function toggleFaq(el){
  const isOpen=el.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i=>{
    i.classList.remove('open');
    i.querySelector('.faq-icon').textContent='+';
  });
  if(!isOpen){
    el.classList.add('open');
    el.querySelector('.faq-icon').textContent='−';
  }
}
function handleSubmit(){
  // Collect form values
  const fname = document.querySelector('input[placeholder="Rahul"]') ? document.querySelector('input[placeholder="Rahul"]').value.trim() : '';
  const lname = document.querySelector('input[placeholder="Sharma"]') ? document.querySelector('input[placeholder="Sharma"]').value.trim() : '';
  const phone = document.querySelector('input[type="tel"]') ? document.querySelector('input[type="tel"]').value.trim() : '';
  const email = document.querySelector('input[type="email"]') ? document.querySelector('input[type="email"]').value.trim() : '';
  const location = document.querySelector('select') ? document.querySelector('select').options[document.querySelector('select').selectedIndex].text : '';
  const selects = document.querySelectorAll('select');
  const treatment = selects[1] ? selects[1].options[selects[1].selectedIndex].text : '';
  const date = document.querySelector('input[type="date"]') ? document.querySelector('input[type="date"]').value : '';

  // Validate required fields
  if (!fname || !phone) {
    alert('Please enter your name and phone number to continue.');
    return;
  }

  const name = (fname + ' ' + lname).trim();

  // Build WhatsApp message
  const waMsg = `Hello Kamakshi Dental,%0A%0AI would like to book an appointment.%0A%0AName: ${encodeURIComponent(name)}%0APhone: ${encodeURIComponent(phone)}%0AEmail: ${encodeURIComponent(email || 'Not provided')}%0ALocation: ${encodeURIComponent(location)}%0ATreatment: ${encodeURIComponent(treatment)}%0APreferred Date: ${encodeURIComponent(date || 'Flexible')}%0A%0APlease confirm my appointment. Thank you!`;

  const waNumber = '919740583538';
  const waURL = `https://wa.me/${waNumber}?text=${waMsg}`;

  // Build Email mailto link for clinic confirmation
  const emailSubject = encodeURIComponent(`New Appointment Request - ${name}`);
  const emailBody = encodeURIComponent(`New appointment request received from the website.\n\nPatient Details:\nName: ${name}\nPhone: ${phone}\nEmail: ${email || 'Not provided'}\nPreferred Location: ${location}\nTreatment Required: ${treatment}\nPreferred Date: ${date || 'Flexible'}\n\nPlease confirm the appointment via WhatsApp or call.`);
  const mailtoURL = `mailto:akarsh.bilimagga@gmail.com?subject=${emailSubject}&body=${emailBody}`;

  // Open WhatsApp
  window.open(waURL, '_blank');

  // Send email notification after short delay
  setTimeout(() => {
    window.open(mailtoURL, '_blank');
  }, 1500);

  // Show confirmation message
  setTimeout(() => {
    alert('Your appointment request has been sent!\n\n1. WhatsApp message sent to Kamakshi Dental\n2. Our team will confirm within 30 minutes\n\nThank you for choosing Kamakshi Dental!');
  }, 500);
}
</script>

